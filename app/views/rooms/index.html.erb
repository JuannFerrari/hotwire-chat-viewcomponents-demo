<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="mb-8">
      <% if notice %>
        <div class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-md" role="alert">
          <p id="notice"><%= notice %></p>
        </div>
      <% end %>
      
      <div class="flex justify-between items-center">
        <h1 class="text-3xl font-bold text-gray-900">Rooms</h1>
        <%= link_to 'New Room', new_room_path, 
            class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition duration-150 ease-in-out shadow-sm hover:shadow-md" %>
      </div>
    </div>

    <!-- Table Section -->
    <div class="bg-white shadow-sm rounded-lg overflow-hidden">
      <% if @rooms.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                  Name
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                  Actions
                </th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @rooms.each do |room| %>
                <tr class="hover:bg-gray-50 transition duration-150 ease-in-out">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">
                      <%= room.name %>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <div class="flex justify-end space-x-2">
                      <%= link_to 'Show', room, 
                          class: "text-blue-600 hover:text-blue-900 font-medium transition duration-150 ease-in-out" %>
                      <%= link_to 'Edit', edit_room_path(room), 
                          class: "text-indigo-600 hover:text-indigo-900 font-medium transition duration-150 ease-in-out" %>
                      <%= button_to 'Destroy', room, 
                          method: :delete, 
                          data: { turbo_confirm: 'Are you sure?' },
                          class: "cursor-pointer text-red-600 hover:text-red-900 font-medium transition duration-150 ease-in-out" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="text-center py-12">
          <div class="mx-auto h-12 w-12 text-gray-400">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No rooms</h3>
          <p class="mt-1 text-sm text-gray-500">Get started by creating a new room.</p>
          <div class="mt-6">
            <%= link_to 'New Room', new_room_path, 
                class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
