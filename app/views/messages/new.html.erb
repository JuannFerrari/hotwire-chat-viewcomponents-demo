<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <h1 class="text-3xl font-bold text-gray-900">New Message</h1>
      </div>
    </div>

    <!-- Form Section -->
    <div class="bg-white shadow-sm rounded-lg overflow-hidden">
      <div class="px-6 py-8">
        <%= turbo_frame_tag "new_message", target: "_top" do %>
          <%= form_with(model: [ @message.room, @message ],
                data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" },
                class: "space-y-6") do |form| %>
            <div>
              <%= form.label :content, "Message", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.text_field :content, 
                  class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm",
                  placeholder: "Type your message here..." %>
            </div>

            <div class="flex items-center justify-end space-x-3 pt-6 border-t border-gray-200">
              <%= form.submit "Send Message", 
                  class: "bg-blue-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition duration-150 ease-in-out" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
